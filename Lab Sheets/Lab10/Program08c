#include <stdio.h>
#include <stdlib.h>

// Merge function
void merge(int arr[], int low, int mid, int high) {
    int n1 = mid - low + 1;
    int n2 = high - mid;

    int* left = (int*)malloc(n1 * sizeof(int));
    int* right = (int*)malloc(n2 * sizeof(int));

    // copy elements
    for (int i = 0; i < n1; i++) left[i] = arr[low + i];

    for (int j = 0; j < n2; j++) right[j] = arr[mid + 1 + j];

    int i = 0, j = 0, k = low;

    // merge sorted arrays
    while (i < n1 && j < n2) {
        if (left[i] <= right[j]) {
            arr[k++] = left[i++];
        } else {
            arr[k++] = right[j++];
        }
    }

    // remaining elements
    while (i < n1) arr[k++] = left[i++];

    while (j < n2) arr[k++] = right[j++];

    free(left);
    free(right);
}

// Count pairs across halves
int countPairs(int arr[], int low, int mid, int high) {
    int count = 0;
    int j = mid + 1;

    for (int i = low; i <= mid; i++) {
        // move j until condition fails
        while (j <= high && arr[i] > 2LL * arr[j]) {
            j++;
        }
        count += (j - (mid + 1));
    }

    return count;
}

// Merge sort + counting
int mergeSort(int arr[], int low, int high) {
    int count = 0;

    if (low < high) {
        int mid = (low + high) / 2;

        // left + right
        count += mergeSort(arr, low, mid);
        count += mergeSort(arr, mid + 1, high);

        // count cross pairs
        count += countPairs(arr, low, mid, high);

        // merge step
        merge(arr, low, mid, high);
    }

    return count;
}

int main() {
    int n;
    scanf("%d", &n);

    int* arr = (int*)malloc(n * sizeof(int));

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int result = mergeSort(arr, 0, n - 1);

    printf("%d\n", result);

    return 0;
}